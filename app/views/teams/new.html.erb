<h1>Create a New Team</h1>

<%= form_with(model: @team, local: true) do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description %>
  </div>

  <%= form.submit "Create Team" %>
<% end %>
<%= link_to 'Back to Teams', teams_path, method: :get%>