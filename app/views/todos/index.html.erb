<h1>ToDo List</h1>

<div>
    <%= button_to "Sign Out", destroy_user_session_path, method: :delete %>
    <%= button_to "Edit Profile", edit_user_registration_path, method: :get%>
</div>

<p>Sort by:
  <%= link_to 'Due Date', todos_path(sort: 'due_date') %> |
  <%= link_to 'Priority', todos_path(sort: 'priority') %>
</p>
<%= form_tag "/todos", method: "GET" do %>
    <%= label_tag :search_by_title_or_description %>
    <%= text_field_tag :search, params[:search] %>
    <%= submit_tag "Submit" %>
    <%= link_to 'Back to ToDos', todos_path, class: "button" %>
<% end %>

<%= form_with(url: todos_path, method: :get, local: true) do |form| %>
    <%= form.select :category_id, options_for_select([['All Categories', nil]] + Category.all.pluck(:name, :id), selected: params[:category_id]), { include_blank: false } %>
    <%= form.submit 'Filter' %>
<% end %>


<table>
    <thead>
        <tr>
            <th>Completed</th>
            <th>Title</th>
            <th>Description</th>
            <th>Due Date</th>
            <th>Priority</th>
            <th>Category</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% @todos.each do |todo| %>
        <tr>
            <td>
                <%= form_with(model: todo, url: todo_path(todo), method: :patch, local: true) do |f| %>
                    <%= f.check_box :completed, { checked: todo.completed } %>
                    <%= f.submit 'Save' %>
                <% end %>
            </td>
            <td><%= todo.title %></td>
            <td><%= todo.description %></td>
            <td><%= todo.due_date %></td>
            <td><%= todo.priority %></td>
            <td><%= todo.category&.name || "No Category" %></td>
            <td>
                <%= button_to 'Edit', edit_todo_path(todo), method: :get %><%= button_to 'Delete', todo_path(todo), method: :delete, form: { data: { turbo_confirm: 'Are you sure you want to delete this item?' } } %>
            </td>
        </tr>
        <% end %>
    </tbody>
</table>


<%= link_to 'Create New ToDo', new_todo_path %>