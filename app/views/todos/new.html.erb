<h1>Create New ToDo</h1>

<%= form_with model: @todo, url: todos_path, local: true do |form| %>
    <div>
    <%= form.label :title, "Title" %>
    <%= form.text_field :title %>
    </div>

    <div>
    <%= form.label :description, "Description" %>
    <%= form.text_area :description %>
    </div>

    <div>
    <%= form.label :due_date, "Due Date" %>
    <%= form.date_select :due_date %>
    </div>

    <div>
    <%= form.label :priority, "Priority" %>
    <%= form.select :priority, options_for_select([['Low', 'low'], ['Medium', 'medium'], ['High', 'high']]) %>
    </div>

    <div class="field">
      <%= form.label :category_id, "Category" %>
      <%= form.collection_select :category_id, Category.all, :id, :name, prompt: "Select Category" %>
    </div>

    <div>
    <%= form.submit "Create ToDo" %>
    </div>
<% end %>









