<h1>ToDos for <%= @team.name %></h1>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Description</th>
      <th>Due Date</th>
      <th>Priority</th>
    </tr>
  </thead>
  <tbody>
    <% if @todos.present? %>
    <%= debug(@todos) %>
 <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Description</th>
        <th>Due Date</th>
      </tr>
    </thead>
    <tbody>
      <% @todos.each do |todo| %>
        <tr>
          <td><%= todo.title %></td>
          <td><%= todo.description %></td>
          <td><%= todo.due_datetime %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No ToDo items found for this team.</p>
    <% end %>
  </tbody>
</table>

